# .dockerignore
# Only relevant if you ever build a Docker image for the Next.js app.
# Supabase local dev does NOT use this file — the CLI manages its own containers.

node_modules
.next
.env*.local
.env
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase local state — not needed inside an app image
supabase/.branches
supabase/.temp
supabase/seed.sql

# Test and dev artifacts
tests/
playwright-report/
test-results/
coverage/

# OS artifacts
.DS_Store
Thumbs.db
