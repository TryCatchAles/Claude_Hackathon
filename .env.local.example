# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic (Claude AI for mentor matching)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google OAuth app credentials (from Google Cloud Console → Credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Central Google account refresh token (run: npx tsx scripts/get-google-token.ts)
APP_CENTRAL_GOOGLE_REFRESH_TOKEN=your_central_calendar_refresh_token
