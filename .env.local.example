# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# For LOCAL development (after running `supabase start`), use these values.
# The CLI prints the real anon + service_role keys when it starts.
#
# Local:
#   NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<printed by `supabase start`>
#   SUPABASE_SERVICE_ROLE_KEY=<printed by `supabase start`>
#
# Production: replace with values from your Supabase project dashboard.

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_local_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_local_service_role_key

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
# → APIs & Services → Credentials → OAuth 2.0 Client IDs
#
# Add these Authorized Redirect URIs in Google Cloud Console:
#   http://localhost:54321/auth/v1/callback     ← for local Supabase
#   https://<your-project>.supabase.co/auth/v1/callback  ← for production

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google APIs (Calendar + Meet) ─────────────────────────────────────────────
# Used server-side to create Calendar events and validate Meet attendance.
# Obtain via OAuth2 consent flow with scopes:
#   https://www.googleapis.com/auth/calendar
#   https://www.googleapis.com/auth/meetings.space.created
#
# Store a long-lived refresh token here (exchange code for tokens once via
# the OAuth playground or your own script, then save the refresh token).

GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
