# ─────────────────────────────────────────────────────────────────────────────
# .env.local.example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App URL ───────────────────────────────────────────────────────────────────
# LOCAL: leave blank or set to http://localhost:3000
# VERCEL: set to your production URL, e.g. https://mentor-match.vercel.app
#         Used as fallback origin for the Google OAuth redirect when the
#         'origin' request header is absent. Must match your Vercel domain.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# LOCAL (after `supabase start`):
#   NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<printed by `supabase start`>
#   SUPABASE_SERVICE_ROLE_KEY=<printed by `supabase start`>
#
# VERCEL / PRODUCTION: use values from Supabase Cloud dashboard →
#   Project Settings → API → Project URL + anon/public + service_role keys

NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from Supabase dashboard>
SUPABASE_SERVICE_ROLE_KEY=<service_role key from Supabase dashboard>

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/
#   APIs & Services → Credentials → OAuth 2.0 Client IDs
#
# Add ALL of these to Authorized Redirect URIs in Google Cloud Console:
#
#   LOCAL Supabase:
#     http://localhost:54321/auth/v1/callback
#
#   PRODUCTION Supabase Cloud:
#     https://<your-project-ref>.supabase.co/auth/v1/callback
#
# These are Supabase's internal auth endpoints — NOT your app's /auth/callback.
# The app-level /auth/callback is handled internally by Supabase and forwarded.

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Google APIs — Centralized Calendar/Meet service account ───────────────────
# A long-lived refresh token for the Google account that owns the central
# calendar used to create Google Meet sessions for all bookings.
#
# How to obtain:
#   1. Run:  npx tsx scripts/get-google-token.ts
#   2. Sign in with the central Google account
#   3. Copy the refresh_token value printed to the terminal
#
# Required OAuth scopes for this account:
#   https://www.googleapis.com/auth/calendar
#   https://www.googleapis.com/auth/meetings.space.created

APP_CENTRAL_GOOGLE_REFRESH_TOKEN=your_central_account_refresh_token

# ── AI ────────────────────────────────────────────────────────────────────────
# The app uses Google Gemini (gemini-2.5-flash) for mentor matching and fraud
# detection. ANTHROPIC_API_KEY is kept in case the Anthropic SDK is used
# for other purposes in the future.
#
# Get your Gemini API key at: https://aistudio.google.com/app/apikey
# Get your Anthropic API key at: https://console.anthropic.com/

GEMINI_API_KEY=your_gemini_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
